    {# weddingCode hidden input'u sildik! #}

    <div class="mb-4">
        <label class="form-label small fw-bold text-muted">Doğrulama Kodu</label>
        <input type="text" name="code" class="form-control form-control-lg text-center fw-bold" placeholder="000000" maxlength="6" required>
    </div>
