{% extends 'base.html.twig' %}

{% block title %}Kayıt Ol{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">

{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <h1  class="h3 mb-3 font-weight-normal text-center">Yeni Üyelik Oluştur</h1>

                {{ form_start(registrationForm) }}
                {# Genel hata mesajlarını gösterir #}
                {{ form_errors(registrationForm) }}

                <div class="mb-3">
                    {{ form_row(registrationForm.email, { 'attr': {'class': 'form-control'} }) }}
                </div>
                <div class="mb-3">
                    {{ form_row(registrationForm.fullName, { 'attr': {'class': 'form-control'} }) }}
                </div>
                <div class="mb-3">
                    {{ form_row(registrationForm.phone, { 'attr': {'class': 'form-control'} }) }}
                </div>
                <div class="mb-3">
                    {{ form_row(registrationForm.birthYear, { 'attr': {'class': 'form-control'} }) }}
                </div>
                <div class="mb-3">
                    {{ form_row(registrationForm.plainPassword, {
                        'label': 'Şifre',
                        'attr': {'class': 'form-control'}
                    }) }}
                </div>
                <button type="submit" class="btn btn-lg btn-primary w-100">Kayıt Ol</button>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>


{% endblock %}
