{% extends 'base.html.twig' %}

{% block title %}Kayıt Ol - QR Düğün Anı{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    {# intl-tel-input CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@24.5.0/build/css/intlTelInput.css">

    <style>
        .iti { width: 100%; }
        .iti__country-list { color: #1e293b; text-align: left; z-index: 100; }

        /* Giriş ekranındaki gibi çakışmayı önleyen padding ayarı */
        #phone_display {
            padding-left: 90px !important;
        }

        /* İkonun konumu */
        .phone-icon {
            left: 12px !important;
            z-index: 20;
        }
    </style>

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#D4AF37", "background-light": "#f8f8f6" },
                    fontFamily: { "display": ["Work Sans", "sans-serif"] },
                },
            },
        }
    </script>
{% endblock %}

{% block body %}
    <div class="bg-background-light min-h-screen flex items-center justify-center p-4 font-display antialiased">
        <div class="relative w-full max-w-[480px] bg-white rounded-2xl shadow-2xl overflow-hidden border border-primary/10 my-8">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-primary"></div>

            <div class="p-8">
                <div class="text-center mb-8">
                    <div class="inline-flex items-center justify-center size-16 rounded-full bg-primary/10 text-primary mb-4">
                        <span class="material-symbols-outlined text-4xl">person_add</span>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900">Yeni Hesap Oluştur</h2>
                    <p class="text-slate-500 text-sm mt-2">Düğün anılarına ortak olmak için bize katıl.</p>
                </div>

                {% for message in app.flashes('error') %}
                    <div class="bg-red-50 text-red-600 text-xs p-3 rounded-lg border border-red-100 mb-6 text-center">
                        {{ message }}
                    </div>
                {% endfor %}

                <form action="{{ path('app_register') }}" method="POST" id="registerForm" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1 ml-1">Adın</label>
                            <input type="text" name="firstName" placeholder="Ad" required class="w-full h-12 px-4 rounded-xl border-slate-100 bg-slate-50/50 focus:ring-primary focus:border-primary text-sm">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1 ml-1">Soyadın</label>
                            <input type="text" name="lastName" placeholder="Soyad" required class="w-full h-12 px-4 rounded-xl border-slate-100 bg-slate-50/50 focus:ring-primary focus:border-primary text-sm">
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1 ml-1">Telefon Numaran</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute phone-icon top-1/2 -translate-y-1/2 text-slate-400">smartphone</span>
                            <input type="tel" id="phone_display" placeholder="5xx..." required
                                   class="w-full h-12 rounded-xl border-slate-100 bg-slate-50/50 focus:ring-primary focus:border-primary text-sm transition-all">

                            <input type="hidden" name="phoneNumber" id="phoneNumberHidden">
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1 ml-1">Şifre Oluştur (4-8 Karakter)</label>
                        <input type="password" name="password" minlength="4" maxlength="8" placeholder="••••••••" required class="w-full h-12 px-4 rounded-xl border-slate-100 bg-slate-50/50 focus:ring-primary focus:border-primary text-sm">
                    </div>

                    <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 space-y-3">
                        <div class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="kvkk_agree" id="kvkk" required class="mt-1 rounded border-slate-300 text-primary focus:ring-primary">
                            <label for="kvkk" class="text-xs text-slate-600 leading-relaxed">
                                <button type="button" data-bs-toggle="modal" data-bs-target="#kvkkModal" class="text-primary font-bold hover:underline">Kullanıcı Sözleşmesi</button>'ni okudum ve kabul ediyorum.
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="w-full h-14 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:brightness-105 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                        <span>KAYIT OL</span>
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                </form>

                <div class="mt-8 text-center">
                    <p class="text-slate-500 text-sm">Zaten üye misin?
                        <a href="{{ path('app_login') }}" class="text-primary font-bold hover:underline">Giriş Yap</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    {# Sözleşme Modalı #}
    <div class="modal fade" id="kvkkModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-2xl rounded-2xl overflow-hidden">
                <div class="modal-header bg-background-light border-b border-primary/10 py-4 px-6 flex justify-between items-center">
                    <h5 class="modal-title font-bold text-slate-900">Kullanıcı Sözleşmesi</h5>
                    <button type="button" class="text-slate-400 hover:text-slate-600" data-bs-dismiss="modal">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <div class="modal-body p-6 text-slate-600 text-sm leading-relaxed">
                    {% if contract %}
                        {{ contract.content|raw }}
                    {% else %}
                        Sözleşme yüklenemedi, lütfen yöneticiyle iletişime geçin.
                    {% endif %}
                </div>
                <div class="modal-footer bg-slate-50 border-t border-primary/10 p-4 flex justify-end">
                    <button type="button" class="bg-primary text-white font-bold px-6 py-2 rounded-full text-sm" data-bs-dismiss="modal">Anladım</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@24.5.0/build/js/intlTelInput.min.js"></script>
    <script>
        const input = document.querySelector("#phone_display");
        const hiddenInput = document.querySelector("#phoneNumberHidden");
        const form = document.querySelector("#registerForm");

        const iti = window.intlTelInput(input, {
            initialCountry: "tr",
            onlyCountries: ["tr", "de", "fr"],
            separateDialCode: true,
            strictMode: true,
            utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@24.5.0/build/js/utils.js",
        });

        form.onsubmit = function(e) {
            if (iti.isValidNumber()) {
                hiddenInput.value = iti.getNumber();
            } else {
                e.preventDefault();
                alert("Lütfen geçerli bir telefon numarası giriniz.");
            }
        };
    </script>
{% endblock %}
