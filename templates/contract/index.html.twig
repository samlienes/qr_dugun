{% extends 'base.html.twig' %}

{% block title %}Sözleşme Onayı{% endblock %}

{% block body %}
    <div class="container mt-5">
        {# Veritabanındaki başlığı çeker #}
        <h1 class="mb-4">{{ contract.title }}</h1>

        <div class="card shadow-sm mb-4">
            <div class="card-body" style="height: 400px; overflow-y: scroll; white-space: pre-wrap; background-color: #f8f9fa;">
                {# Veritabanındaki metni çeker #}
                {{ contract.content }}
            </div>
        </div>

        <form action="{{ path('app_contract_confirm') }}" method="POST">
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="confirmCheck" required>
                <label class="form-check-label" for="confirmCheck">
                    Sözleşmeyi okudum, anladım ve kabul ediyorum.
                </label>
            </div>
            <button type="submit" class="btn btn-success btn-lg w-100">Onayla ve Devam Et</button>
        </form>
    </div>
{% endblock %}
