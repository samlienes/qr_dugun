{% extends 'base.html.twig' %}

{% block title %}Giriş Yap - {{ wedding.name|default('QR Düğün Anı') }}{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    {# intl-tel-input CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@24.5.0/build/css/intlTelInput.css">

    <style>
        .iti { width: 100%; }
        .iti__country-list { color: #1e293b; text-align: left; z-index: 100; }

        /* ÇAKIŞMAYI ÖNLEYEN KRİTİK AYAR:
           separateDialCode açıkken smartphone ikonu ve ülke kodu için boşluk bırakıyoruz */
        #phone_display {
            padding-left: 90px !important; /* 12 birimden daha fazla yer açtık */
        }

        /* Smartphone ikonunu ülke kodunun biraz daha soluna sabitleyelim */
        .phone-icon {
            left: 12px !important;
            z-index: 20;
        }
    </style>

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#D4AF37",
                        "background-light": "#f8f8f6",
                    },
                    fontFamily: { "display": ["Work Sans", "sans-serif"] },
                },
            },
        }
    </script>
{% endblock %}

{% block body %}
    <div class="bg-background-light min-h-screen flex items-center justify-center p-4 font-display antialiased">
        <div class="relative w-full max-w-[440px] bg-white rounded-2xl shadow-2xl overflow-hidden border border-primary/10">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-primary"></div>

            <div class="p-8">
                <div class="text-center mb-8">
                    <div class="inline-flex items-center justify-center size-16 rounded-full bg-primary/10 text-primary mb-4">
                        <span class="material-symbols-outlined text-4xl">lock_open</span>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900">Tekrar Hoş Geldin</h2>
                    <p class="text-slate-500 text-sm mt-2">Anılara ortak olmak için giriş yap kanka.</p>
                </div>

                {% for message in app.flashes('error') %}
                    <div class="bg-red-50 text-red-600 text-xs p-3 rounded-lg border border-red-100 mb-6 text-center">
                        {{ message }}
                    </div>
                {% endfor %}

                <form action="{{ path('app_login') }}" method="POST" id="loginForm" class="space-y-5">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1 ml-1">Telefon Numaran</label>
                        <div class="relative">
                            {# İkonu phone-icon sınıfı ile özelleştirdik #}
                            <span class="material-symbols-outlined absolute phone-icon top-1/2 -translate-y-1/2 text-slate-400">smartphone</span>

                            <input type="tel" id="phone_display" placeholder="5xx..." required autofocus
                                   class="w-full h-14 rounded-xl border-slate-100 bg-slate-50/50 focus:ring-primary focus:border-primary text-base transition-all">

                            <input type="hidden" name="phoneNumber" id="phoneNumberHidden">
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between mb-1 ml-1">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest">Şifren</label>
                            <a href="{{ path('app_forgot_password') }}" class="text-xs font-bold text-primary hover:underline">Şifremi Unuttum</a>
                        </div>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
                            <input type="password" name="password" id="loginPassword" placeholder="••••••••" required
                                   class="w-full h-14 pl-12 pr-4 rounded-xl border-slate-100 bg-slate-50/50 focus:ring-primary focus:border-primary text-base transition-all">
                            <button type="button" onclick="togglePass()" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400">
                                <span class="material-symbols-outlined" id="passIcon">visibility</span>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="w-full h-14 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:brightness-105 active:scale-[0.98] transition-all flex items-center justify-center gap-2 mt-4">
                        <span>GİRİŞ YAP</span>
                        <span class="material-symbols-outlined">login</span>
                    </button>
                </form>

                <div class="mt-8 text-center">
                    <p class="text-slate-500 text-sm">Hesabın yok mu?
                        <a href="{{ path('app_register') }}" class="text-primary font-bold hover:underline">Şimdi Kayıt Ol</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@24.5.0/build/js/intlTelInput.min.js"></script>
    <script>
        const input = document.querySelector("#phone_display");
        const hiddenInput = document.querySelector("#phoneNumberHidden");
        const form = document.querySelector("#loginForm");

        const iti = window.intlTelInput(input, {
            initialCountry: "tr",
            onlyCountries: ["tr", "de", "fr"],
            separateDialCode: true,
            strictMode: true,
            utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@24.5.0/build/js/utils.js",
        });

        form.onsubmit = function(e) {
            if (iti.isValidNumber()) {
                hiddenInput.value = iti.getNumber();
            } else {
                e.preventDefault();
                alert("Lütfen geçerli bir telefon numarası giriniz.");
            }
        };

        function togglePass() {
            const passInput = document.getElementById('loginPassword');
            const icon = document.getElementById('passIcon');
            if (passInput.type === 'password') {
                passInput.type = 'text';
                icon.innerText = 'visibility_off';
            } else {
                passInput.type = 'password';
                icon.innerText = 'visibility';
            }
        }
    </script>
{% endblock %}
