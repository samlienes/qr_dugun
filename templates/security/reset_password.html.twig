{% extends 'base.html.twig' %}
{% block title %}Yeni Şifre Oluştur{% endblock %}
{% block body %}
    <div class="container mt-5 mb-5" style="max-width: 500px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">Harika!</h2>
            <p class="text-muted">Kimliğini doğruladık. Şimdi yeni bir şifre belirleyebilirsin.</p>
        </div>
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <form action="{{ path('app_reset_password') }}" method="POST">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Yeni Şifre (4-8 Karakter)</label>
                    <input type="password" name="password" id="resetPassword" class="form-control form-control-lg" placeholder="Yeni şifreni gir" minlength="4" maxlength="8" required autofocus>
                </div>
                <div class="mb-4 form-check">
                    <input type="checkbox" class="form-check-input" id="showPasswordCheck">
                    <label class="form-check-label text-muted small" for="showPasswordCheck">Şifreyi Göster</label>
                </div>
                <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">Şifreyi Kaydet ve Giriş Yap</button>
            </form>
        </div>
    </div>
    <script>
        document.getElementById('showPasswordCheck').addEventListener('change', function() {
            document.getElementById('resetPassword').type = this.checked ? 'text' : 'password';
        });
    </script>
{% endblock %}
