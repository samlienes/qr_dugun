{% extends 'base.html.twig' %}
{% block body %}
    <div class="container mt-5 flex justify-center">
        <div class="card border-0 shadow-lg rounded-4 p-5 text-center" style="max-width: 400px; border-top: 5px solid #D4AF37 !important;">
            <h2 class="fw-bold mb-3">Kodu Doğrula</h2>
            <p class="text-muted mb-4">Telefonuna gelen 6 haneli kodu gir.</p>

            <form action="{{ path('app_forgot_password_verify') }}" method="POST">
                <input type="hidden" name="phoneNumber" value="{{ phoneNumber }}">
                <input type="text" name="code" class="form-control form-control-lg text-center fw-bold mb-4" placeholder="000000" maxlength="6" required>
                <button type="submit" class="btn btn-primary btn-lg w-100">Onayla</button>
            </form>
        </div>
    </div>
{% endblock %}
