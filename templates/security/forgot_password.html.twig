{% extends 'base.html.twig' %}
{% block title %}Şifremi Unuttum{% endblock %}
{% block body %}
    <div class="container mt-5 mb-5" style="max-width: 500px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">Şifreni mi Unuttun?</h2>
            <p class="text-muted">Dert etme kanka. Kayıtlı numaranı gir, SMS kodu gönderelim.</p>
        </div>
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <form action="{{ path('app_forgot_password') }}" method="POST">
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">Telefon Numaran</label>
                    <input type="tel" name="phoneNumber" class="form-control form-control-lg" placeholder="05xx..." required autofocus>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">Kodu Gönder</button>
            </form>
        </div>
    </div>
{% endblock %}
