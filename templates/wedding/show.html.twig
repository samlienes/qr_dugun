{% extends 'base.html.twig' %}

{% block title %}{{ wedding.title }} - Hoş Geldiniz{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { "primary": "#D4AF37", "background-light": "#f8f8f6" },
                    fontFamily: { "display": ["Work Sans", "sans-serif"] },
                },
            },
        }
    </script>
    <style>
        .gold-gradient { background: linear-gradient(135deg, #D4AF37 0%, #EEDC82 100%); }
    </style>
{% endblock %}

{% block body %}
    <div class="relative flex min-h-screen w-full max-w-md mx-auto flex-col bg-background-light shadow-2xl font-display antialiased pb-24">

        <div class="relative h-64 w-full overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?q=80&w=2070&auto=format&fit=crop');"></div>
            <div class="absolute inset-0 bg-black/40 flex flex-col items-center justify-center text-white p-6 text-center">
                <span class="material-symbols-outlined text-primary text-5xl mb-2" style="font-variation-settings: 'FILL' 1">favorite</span>
                <h1 class="text-3xl font-bold tracking-tight uppercase">{{ wedding.title }}</h1>
                <div class="h-px w-24 bg-primary my-3"></div>
                <p class="text-sm font-medium tracking-widest">{{ wedding.date ? wedding.date|date('d F Y') : 'Tarih Belirtilmedi' }}</p>
            </div>
        </div>

        <div class="mx-4 -mt-8 relative z-10 bg-white rounded-2xl shadow-xl p-5 border border-primary/10 flex items-center justify-between">
            <div>
                <p class="text-[10px] font-bold text-primary uppercase tracking-[0.3em] mb-1 flex items-center gap-1">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute h-full w-full rounded-full bg-red-500 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                    </span>
                    Canlı Durum
                </p>
                <h2 class="text-xl font-black text-slate-800">Büyük Gün Geldi!</h2>
                <p class="text-xs text-slate-500 mt-1">Şu ana kadar <strong class="text-primary">{{ photoCount }}</strong> anı paylaşıldı.</p>
            </div>
            <div class="size-14 rounded-full bg-primary/10 flex items-center justify-center text-primary shadow-inner">
                <span class="material-symbols-outlined text-3xl animate-pulse" style="font-variation-settings: 'FILL' 1">celebration</span>
            </div>
        </div>

        <div class="px-4 py-8 grid grid-cols-1 gap-4">
            <a href="{{ path('app_wedding_upload', {'weddingCode': wedding.weddingCode}) }}"
               class="group relative flex items-center p-6 bg-white rounded-2xl shadow-sm border border-primary/5 hover:border-primary/30 transition-all">
                <div class="size-14 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-3xl">add_a_photo</span>
                </div>
                <div class="ml-5 flex-1">
                    <h3 class="font-bold text-slate-800">Anılarını Paylaş</h3>
                    <p class="text-xs text-slate-500 mt-1">Gecenin en güzel karelerini yükle.</p>
                </div>
                <span class="material-symbols-outlined text-slate-300">chevron_right</span>
            </a>

            <a href="{{ path('app_wedding_gallery', {'weddingCode': wedding.weddingCode}) }}"
               class="group relative flex items-center p-6 bg-white rounded-2xl shadow-sm border border-primary/5 hover:border-primary/30 transition-all">
                <div class="size-14 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-3xl">auto_awesome_motion</span>
                </div>
                <div class="ml-5 flex-1">
                    <div class="flex items-center gap-2">
                        <h3 class="font-bold text-slate-800">Canlı Galeri</h3>
                        <span class="bg-primary/20 text-primary text-[9px] px-2 py-0.5 rounded-full font-bold uppercase">{{ photoCount }} Fotoğraf</span>
                    </div>
                    <p class="text-xs text-slate-500 mt-1">Diğer misafirlerin karelerine göz at.</p>
                </div>
                <span class="material-symbols-outlined text-slate-300">chevron_right</span>
            </a>
        </div>

        <div class="px-4 pb-8">
            <div class="bg-slate-900 rounded-2xl p-6 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10">
                    <span class="material-symbols-outlined text-7xl">map</span>
                </div>
                <h4 class="text-primary text-[10px] font-bold uppercase tracking-[0.2em] mb-2">Düğün Mekanı</h4>
                <p class="text-xl font-bold mb-1">{{ wedding.weddingHall ? wedding.weddingHall.name : 'Henüz Belirlenmedi' }}</p>
                <p class="text-xs text-slate-400 mb-6">Seni aramızda görmek için sabırsızlanıyoruz!</p>
                {% if wedding.weddingHall and wedding.weddingHall.latitude %}
                    <a href="https://www.google.com/maps/dir/?api=1&destination={{ wedding.weddingHall.latitude }},{{ wedding.weddingHall.longitude }}"
                       target="_blank"
                       class="inline-flex items-center gap-2 bg-primary text-slate-900 px-5 py-3 rounded-xl font-bold text-sm shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined text-sm">directions</span>
                        Yol Tarifi Al
                    </a>
                {% endif %}
            </div>
        </div>

        <nav class="fixed bottom-0 w-full max-w-md bg-white border-t border-slate-100 flex justify-around py-3 pb-6 z-50 shadow-[0_-4px_20px_rgba(0,0,0,0.05)]">
            <a href="{{ path('app_wedding_show', {'weddingCode': wedding.weddingCode}) }}" class="flex flex-col items-center {% if app.request.attributes.get('_route') == 'app_wedding_show' %}text-[#D4AF37]{% else %}text-slate-400 hover:text-[#D4AF37]{% endif %} transition-colors">
                <span class="material-symbols-outlined {% if app.request.attributes.get('_route') == 'app_wedding_show' %}fill-1{% endif %}">home</span>
                <span class="text-[10px] font-bold mt-1 uppercase">Feed</span>
            </a>
            <a href="{{ path('app_wedding_upload', {'weddingCode': wedding.weddingCode}) }}" class="flex flex-col items-center {% if app.request.attributes.get('_route') == 'app_wedding_upload' %}text-[#D4AF37]{% else %}text-slate-400 hover:text-[#D4AF37]{% endif %} transition-colors">
                <span class="material-symbols-outlined {% if app.request.attributes.get('_route') == 'app_wedding_upload' %}fill-1{% endif %}">cloud_upload</span>
                <span class="text-[10px] font-bold mt-1 uppercase">Upload</span>
            </a>
            <a href="{{ path('app_wedding_gallery', {'weddingCode': wedding.weddingCode}) }}" class="flex flex-col items-center {% if app.request.attributes.get('_route') == 'app_wedding_gallery' %}text-[#D4AF37]{% else %}text-slate-400 hover:text-[#D4AF37]{% endif %} transition-colors">
                <span class="material-symbols-outlined {% if app.request.attributes.get('_route') == 'app_wedding_gallery' %}fill-1{% endif %}">favorite</span>
                <span class="text-[10px] font-bold mt-1 uppercase">Gallery</span>
            </a>
            <a href="{{ path('app_wedding_profile', {'weddingCode': wedding.weddingCode}) }}" class="flex flex-col items-center {% if app.request.attributes.get('_route') == 'app_wedding_profile' %}text-[#D4AF37]{% else %}text-slate-400 hover:text-[#D4AF37]{% endif %} transition-colors">
                <span class="material-symbols-outlined {% if app.request.attributes.get('_route') == 'app_wedding_profile' %}fill-1{% endif %}">person</span>
                <span class="text-[10px] font-bold mt-1 uppercase">Profile</span>
            </a>
        </nav>
    </div>
{% endblock %}
