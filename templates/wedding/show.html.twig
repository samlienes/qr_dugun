{% extends 'base.html.twig' %}

{% block title %}{{ wedding.name }} | QR Düğün Anı{% endblock %}

{% block body %}
    <script>
        function checkLocation() {
            const salonLat = {{ wedding.weddingHall.latitude ?? 0 }};
            const salonLng = {{ wedding.weddingHall.longitude ?? 0 }};
            const maxDistance = 150;

            if (!navigator.geolocation) return;

            navigator.geolocation.getCurrentPosition((position) => {
                const distance = calculateDistance(position.coords.latitude, position.coords.longitude, salonLat, salonLng);
                if (distance > maxDistance && document.getElementById('upload-button')) {
                    alert(`Salona uzaksın (${Math.round(distance)}m). Yükleme yapılamaz.`);
                    document.getElementById('upload-button').disabled = true;
                }
            });
        }

        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371e3;
            const p1 = lat1 * Math.PI/180, p2 = lat2 * Math.PI/180;
            const dp = (lat2-lat1) * Math.PI/180, dl = (lon2-lon1) * Math.PI/180;
            const a = Math.sin(dp/2)**2 + Math.cos(p1) * Math.cos(p2) * Math.sin(dl/2)**2;
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        }
        window.onload = checkLocation;
    </script>

    <div class="container mt-5 text-center">
        <div class="mb-5 animate__animated animate__fadeIn">
            <i class="fas fa-heart text-danger mb-3" style="font-size: 2.5rem;"></i>
            <h1 class="display-4 text-primary fw-bold">{{ wedding.name }}</h1>
            <p class="lead text-muted"><i class="far fa-calendar-alt me-2"></i>{{ wedding.weddingDate|date('d.m.Y H:i') }}</p>
        </div>

        <div class="row g-4 justify-content-center">
            {# 1. KART: FOTOĞRAF YÜKLEME #}
            <div class="col-md-5">
                <div class="card h-100 shadow-lg border-0 transition-card">
                    <div class="card-body p-5">
                        <div class="icon-circle bg-info text-white mb-4 mx-auto shadow-sm">
                            <i class="fas fa-camera-retro fa-2x"></i>
                        </div>
                        <h3 class="fw-bold">Anı Paylaş</h3>

                        {% if isLoggedIn %}
                            <p class="text-muted small">Anıları yükle, sözleşmeyi onaylamayı unutma kanka.</p>

                            {# Sözleşme Onayı #}
                            <div class="mb-4 text-start p-2 border rounded bg-light">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="contractCheck">
                                    <label class="form-check-label small" for="contractCheck">
                                        <strong>{{ wedding.activeContract.title }} ({{ wedding.activeContract.version }})</strong> onaylıyorum.
                                    </label>
                                </div>
                            </div>

                            <form id="uploadForm">
                                <input type="file" id="photoInput" name="photo" accept="image/*" style="display: none;">
                                <button id="upload-button" type="button" onclick="document.getElementById('photoInput').click()" class="btn btn-info btn-lg text-white w-100 shadow-sm fw-bold">
                                    <i class="fas fa-upload me-2"></i>Fotoğraf Seç ve Yükle
                                </button>
                            </form>
                            <div id="uploadStatus" class="mt-3 p-2 rounded d-none"></div>
                        {% else %}
                            <div class="alert alert-warning mt-4">
                                Fotoğraf yüklemek için önce <a href="{{ path('app_home', {'weddingCode': wedding.weddingCode}) }}" class="fw-bold">giriş yapmalısın</a>.
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# 2. KART: GALERİYE GİT #}
            <div class="col-md-5">
                <div class="card h-100 shadow-lg border-0 transition-card">
                    <div class="card-body p-5">
                        <div class="icon-circle bg-warning text-white mb-4 mx-auto shadow-sm">
                            <i class="fas fa-images fa-2x"></i>
                        </div>
                        <h3 class="fw-bold">Galeri</h3>
                        <p class="text-muted small">Yüklenen tüm fotoğrafları keşfet.</p>
                        <a href="#" class="btn btn-warning btn-lg text-white w-100 mt-4 shadow-sm fw-bold disabled">Galeriyi Gör (Yakında)</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .transition-card { transition: all 0.3s ease; }
        .transition-card:hover { transform: translateY(-10px); box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important; }
        .icon-circle { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    </style>

    <script>
        document.getElementById('photoInput').onchange = function() {
            const check = document.getElementById('contractCheck');
            if (!check || !check.checked) {
                alert("Önce sözleşmeyi onaylaman lazım kanka!");
                this.value = ""; return;
            }

            const statusDiv = document.getElementById('uploadStatus');
            const formData = new FormData();
            formData.append('photo', this.files[0]);

            statusDiv.classList.remove('d-none', 'alert-success', 'alert-danger');
            statusDiv.classList.add('alert-info');
            statusDiv.innerHTML = 'Yükleniyor...';

            fetch("{{ path('app_photo_upload', {'weddingCode': wedding.weddingCode}) }}", { method: "POST", body: formData })
                .then(r => r.json())
                .then(data => {
                    statusDiv.classList.replace('alert-info', data.status === 'success' ? 'alert-success' : 'alert-danger');
                    statusDiv.innerHTML = data.status === 'success' ? 'Başarıyla yüklendi!' : 'Hata: ' + data.message;
                    if(data.status === 'success') this.value = "";
                });
        };
    </script>
{% endblock %}
